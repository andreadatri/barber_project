      "description": "Input field styling"
    },
    "ring": {
      "DEFAULT": "#8b6914",
      "description": "Focus ring color (matches primary)"
    }
  },
  "spacing": {
    "xs": "0.25rem",
    "sm": "0.5rem",
    "md": "1rem",
    "lg": "1.5rem",
    "xl": "2rem",
    "2xl": "3rem",
    "description": "Standard spacing scale (Tailwind-compatible: 1 = 0.25rem = 4px)",
    "tailwind_mapping": {
      "1": "4px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
