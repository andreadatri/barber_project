      "sm": {
        "size": "0.875rem",
        "lineHeight": "1.5",
        "description": "Small text (14px)"
      },
      "lg": {
        "size": "1.125rem",
        "lineHeight": "1.5",
        "description": "Large text (18px)"
      },
      "xl": {
        "size": "1.25rem",
        "lineHeight": "1.5",
        "description": "Extra large - h2 headings (20px)"
      },
      "2xl": {
        "size": "1.5rem",
        "lineHeight": "1.5",
        "description": "2XL - h1 headings (24px)"
