      "5xl": {
        "size": "3rem",
        "lineHeight": "1.1",
        "description": "5XL - landing hero (48px)"
      }
    },
    "fontWeight": {
      "normal": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700",
      "description": "Font weight scale - medium (500) used for headings, labels, buttons"
    },
    "lineHeight": {
      "tight": "1.1",
      "snug": "1.2",
      "normal": "1.5",
      "relaxed": "1.625",
      "description": "Line height values"
    }
  },
  "borderRadius": {
    "sm": "calc(0.625rem - 4px)",
    "md": "calc(0.625rem - 2px)",
    "lg": "0.625rem",
    "xl": "calc(0.625rem + 4px)",
    "description": "Border radius scale - base is 10px (0.625rem)",
    "tailwind_values": {
      "sm": "6px",
      "md": "8px",
      "lg": "10px",
      "xl": "14px",
      "rounded-md": "0.375rem (6px)",
      "rounded-lg": "0.5rem (8px)",
      "rounded-xl": "0.75rem (12px)"
    }
  },
  "shadows": {
    "sm": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
    "DEFAULT": "0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)",
    "md": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
    "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)",
    "xl": "0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1)",
    "description": "Standard Tailwind shadow scale - subtle shadows for depth"
  },
  "focusRing": {
    "color": "#8b6914",
    "opacity": "50%",
    "width": "3px",
    "description": "Focus ring for accessibility (AA compliant) - 3px ring with 50% opacity primary color"
  },
  "transitions": {
    "DEFAULT": "all 150ms cubic-bezier(0.4, 0, 0.2, 1)",
    "colors": "color 150ms cubic-bezier(0.4, 0, 0.2, 1), background-color 150ms cubic-bezier(0.4, 0, 0.2, 1), border-color 150ms cubic-bezier(0.4, 0, 0.2, 1)",
    "description": "Smooth transitions for interactive elements"
  },
  "components": {
    "button": {
      "sizes": {
        "sm": {
          "height": "2rem (32px)",
          "padding": "0.75rem (12px)",
          "description": "Small button"
        },
        "default": {
          "height": "2.25rem (36px)",
          "padding": "1rem (16px)",
          "description": "Default button"
        },
        "lg": {
          "height": "2.5rem (40px)",
          "padding": "1.5rem (24px)",
          "description": "Large button"
        },
        "icon": {
          "size": "2.25rem (36px)",
          "description": "Square icon button"
        }
      },
      "variants": {
        "default": "Primary background, white text, 90% opacity on hover",
        "destructive": "Red background, white text, destructive ring on focus",
        "outline": "Border with background on hover",
        "secondary": "Secondary background, 80% opacity on hover",
        "ghost": "Transparent, accent background on hover",
        "link": "Underline on hover, primary color"
      }
    },
    "card": {
      "padding": "1.5rem (24px)",
      "borderRadius": "0.75rem (12px)",
      "gap": "1.5rem (24px)",
      "description": "Card container with border and rounded corners"
    },
    "input": {
      "height": "2.25rem (36px)",
      "padding": "0.5rem (8px)",
      "background": "#f3f3f5",
      "borderRadius": "0.375rem (6px)",
      "fontSize": "16px",
      "description": "Form input fields"
    }
  },
  "layout": {
    "container": {
      "maxWidth": "80rem (1280px)",
      "padding": "1rem (16px)",
      "description": "Main content container"
    },
    "breakpoints": {
      "sm": "640px",
      "md": "768px",
      "lg": "1024px",
      "xl": "1280px",
      "2xl": "1536px",
      "description": "Tailwind default breakpoints"
    }
  },
  "accessibility": {
    "focusVisible": {
      "ring": "3px solid primary/50",
      "borderColor": "primary",
      "description": "Visible focus indicators for keyboard navigation (WCAG AA compliant)"
    },
    "errorStates": {
      "ring": "destructive/20",
      "borderColor": "destructive",
      "description": "Error indication with red ring and border"
    },
    "minTouchTarget": "44px",
    "description": "Minimum touch target size for mobile (WCAG 2.5.5)"
  },
  "metadata": {
    "version": "1.0.0",
    "framework": "Tailwind CSS v4",
    "designSystem": "Barber Shop PWA",
    "colorPalette": "Warm brown/gold with neutral cream/beige accents",
    "language": "Italian (it-IT)",
    "mobileFirst": true,
    "pwaReady": true,
    "a11y": "WCAG AA compliant",
    "notes": [
      "Uses CSS custom properties for theming",
      "Dark mode variants included in theme.css",
      "Focus rings use primary color at 50% opacity with 3px width",
      "All interactive elements have hover/focus/disabled states",
      "Mobile-first responsive design",
      "16px base font size for better mobile readability"
    ]
  }
